# ============================================
# Configuration Hydr'Hacked
# Renommez ce fichier en .env et remplissez les valeurs
# ============================================

# ==========================================
# SOURCE PAR DÉFAUT : Zone-Telechargement
# ==========================================

# L'URL du site Zone-Telechargement (OBLIGATOIRE)
ZT_BASE_URL=  # L'URL complète du site ZT en HTTPS

# ==========================================
# SOURCE OPTIONNELLE : Hydracker (Token)
# ==========================================

# URL du site Hydracker (optionnel, uniquement si vous avez un token)
BASE_URL=

# Clé API récupérée depuis l'inspecteur réseau (Authorization: Bearer XXXXXX)
DW_API_KEY=

# ==========================================
# CONFIGURATION APPLICATION
# ==========================================

# Port de l'application (optionnel, 3000 par défaut)
PORT=3000

# Mot de passe pour déverrouiller l'interface web
API_PASSWORD=hydracker

# Clé secrète pour les sessions (n'importe quelle chaîne aléatoire)
SECRET=changez-moi-par-une-chaine-aleatoire

# Intervalle (en minutes) entre chaque vérification automatique des tendances
MIN_MINUTES=15
MAX_MINUTES=30

# (Optionnel) Configuration JDownloader si vous utilisez l'intégration
# JD_HOST=192.168.1.100
# JD_API_PORT=3128
